{
  "name": "innomcp-workspace",
  "version": "1.0.0",
  "description": "INNOMCP AI Chatbot with MCP Tools - Monorepo Workspace (pnpm)",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "concurrently -n \"BACKEND,MCP,FRONTEND\" -c \"cyan,magenta,green\" \"pnpm run dev:backend\" \"pnpm run dev:mcp\" \"pnpm run dev:frontend\"",
    "dev:backend": "pnpm --filter innomcp-node run dev",
    "dev:mcp": "pnpm --filter innomcp-server-node run dev",
    "dev:frontend": "pnpm --filter innomcp-next run dev",
    "dev:logged": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-logged.ps1",
    "build": "pnpm run build:backend && pnpm run build:mcp && pnpm run build:frontend",
    "build:backend": "pnpm --filter innomcp-node run build",
    "build:mcp": "pnpm --filter innomcp-server-node run build",
    "build:frontend": "pnpm --filter innomcp-next run build",
    "start": "concurrently -n \"BACKEND,MCP,FRONTEND\" -c \"cyan,magenta,green\" \"pnpm run start:backend\" \"pnpm run start:mcp\" \"pnpm run start:frontend\"",
    "start:backend": "pnpm --filter innomcp-node run start",
    "start:mcp": "pnpm --filter innomcp-server-node run start",
    "start:frontend": "pnpm --filter innomcp-next run start",
    "kill": "bash ./kill-all-processes.sh",
    "test": "bash ./test-performance.sh",
    "test:mcp": "curl -X POST http://localhost:3012/mcp -H 'Content-Type: application/json' -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}'",
    "install:all": "pnpm install",
    "clean": "rm -rf node_modules innomcp-next/node_modules innomcp-node/node_modules innomcp-server-node/node_modules",
    "clean:dist": "rm -rf innomcp-next/.next innomcp-node/dist innomcp-server-node/dist",
    "lint": "pnpm run lint:frontend && pnpm run lint:backend",
    "lint:frontend": "pnpm --filter innomcp-next run lint",
    "lint:backend": "pnpm --filter innomcp-node run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "install-hooks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-hooks.ps1",
    "hooks:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-hooks.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.1.2",
    "jest": "^30.2.0",
    "node-fetch": "^2.7.0",
    "ts-jest": "^29.4.6"
  },
  "overrides": {
    "zod": "3.22.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/innomcp.git"
  },
  "keywords": [
    "ai",
    "chatbot",
    "mcp",
    "model-context-protocol",
    "ollama",
    "nextjs",
    "nodejs",
    "typescript",
    "websocket",
    "streaming"
  ],
  "author": "INNOMCP Team",
  "license": "MIT",
  "dependencies": {
    "@types/winston": "^2.4.4",
    "winston": "^3.19.0"
  }
}
