# ============================================================
# innomcp-server-node — Environment Variables Reference
# ห้ามใส่ secret จริงในไฟล์นี้ — copy เป็น .env แล้วกรอกค่าจริง
# ============================================================

# ------------------------------------------------------------
# OPERATING MODE (กติกาหลัก)
# offline = ห้ามยิง external API (ใช้ fixture/smoke), ไม่ต้องมี key จริง
# online  = ต้องมี key จริงครบ (TMD_UID, NWP_API_KEY ฯลฯ)
# ------------------------------------------------------------
INNOMCP_MODE=offline

# SMOKE_MODE=1 เปิดโหมด smoke-test ภายใน (ใช้ร่วมกับ offline)
# เมื่อเปิด: tmdTools จะไม่ยิง HTTP จริง, สามารถบังคับ delay/timeout ได้
SMOKE_MODE=0

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
SERVER_HOST=127.0.0.1
SERVER_PORT=3012
LOG_MODE=dev              # dev | prod
NODE_ENV=development      # development | production
ENABLE_FILE_LOG=true      # เขียน log ลงไฟล์ด้วยหรือไม่

# CORS: comma-separated origins ที่อนุญาต
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3011

# ------------------------------------------------------------
# App DB (MariaDB — innomcp main database)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=innomcp

# Docker MariaDB (ใช้โดย compose/seed scripts เท่านั้น)
MARIADB_ROOT_PASSWORD=
MARIADB_PASSWORD=

# ------------------------------------------------------------
# DetectDB (Evidence DB — สำหรับ evidenceTool)
# ใช้โดย: evidenceTool.ts, dbDetect.ts
# ------------------------------------------------------------
DETECT_DB_HOST=127.0.0.1
DETECT_DB_PORT=3308
DETECT_DB_USER=root
DETECT_DB_PASSWORD=
DETECT_DB_NAME=phase91_detectdb

# ------------------------------------------------------------
# TMD API (กรมอุตุนิยมวิทยา)
# ใช้โดย: tmdTools.ts (17 tools)
# ขอ credential ได้ที่ https://data.tmd.go.th/
# [REQUIRED ถ้า INNOMCP_MODE=online]
# NOTE: ชื่อเก่า TMD_API_UID / TMD_API_UKEY ถูกเลิกใช้และจะถูก ignore
# ------------------------------------------------------------
TMD_UID=
TMD_UKEY=

# Smoke-test helpers (ใช้เมื่อ SMOKE_MODE=1 เท่านั้น)
WX_TMD_DELAY_MS=0            # หน่วง request ทุก tool (ms)
WX_TMD_STATION_DELAY_MS=0    # หน่วงเฉพาะ station tools (ms)
WX_TMD_TIMEOUT_MS=0          # บังคับ timeout (ms, 0 = ใช้ default 30000)

# ------------------------------------------------------------
# NWP API (คอมพิวเตอร์สมรรถนะสูง TMD)
# ใช้โดย: nwpDailyTool.ts, nwpHourlyTool.ts (6 tools รวม)
# Token แบบ Bearer JWT หมดอายุ 2028
# [REQUIRED ถ้า INNOMCP_MODE=online]
# ------------------------------------------------------------
NWP_API_KEY=

# ------------------------------------------------------------
# WEBDDSB (Web Domain Statistics Backend)
# ใช้โดย: webdTools.ts (3 tools: group/platform/domain)
# [REQUIRED ถ้าต้องการใช้ webd tools]
# ------------------------------------------------------------
WEBDDSB_HOST=localhost
WEBDDSB_PORT=3011
WEBDDSB_APIKEY=

# ------------------------------------------------------------
# OpenWeather API (weatherTool.ts)
# ขอ key ฟรีได้ที่ https://openweathermap.org/api
# [OPTIONAL — tool จะ error ถ้าไม่มี]
# ------------------------------------------------------------
OPENWEATHER_API_KEY=

# ------------------------------------------------------------
# NASA Open Data API (nasaTool.ts)
# ใช้ DEMO_KEY ได้ถ้าไม่ต้องการ rate limit สูง
# ขอ key ที่ https://api.nasa.gov/
# [OPTIONAL — default: DEMO_KEY]
# ------------------------------------------------------------
NASA_API_KEY=DEMO_KEY

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
USE_INTELLIGENCE_PIPELINE=false   # เปิด Intelligence Pipeline (Phase 4)

# Fixture/QA flags (ใช้ในชุดทดสอบ)
WEATHER_FIXTURE_W1=0   # 1 = ใช้ fixture w1 แทนการยิง API จริง
CHAT_TRACE_QA=0        # 1 = เปิด chat trace mode สำหรับ QA
