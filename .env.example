# ============================================================
# innomcp — Root Docker Compose Environment Variables
# Copy as .env and fill in real values. Never commit secrets.
# ============================================================

# ------------------------------------------------------------
# Database (MariaDB)
# Host port 3308 maps to container port 3306 (avoids conflict
# with any local MariaDB install — matches dev convention)
# ------------------------------------------------------------
MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_PASSWORD=change_me_pass
DB_NAME=innomcp-db
DB_USER=jlapps

# ------------------------------------------------------------
# Operating mode
# offline = use fixtures/smoke, no external API calls
# online  = real credentials required
# ------------------------------------------------------------
INNOMCP_MODE=online

# ------------------------------------------------------------
# LLM / AI Providers (leave empty if not using)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_COPILOT_TOKEN=

# MDES Ollama (remote)
OLLAMA_URL=https://ollama.mdes-innova.online
OLLAMA_API_KEY=

# Parallel MDES agent dispatch
# 0 = disabled (safe default), 1 = enabled (requires OLLAMA_API_KEY)
PARALLEL_AGENTS=0

# ------------------------------------------------------------
# Workspace (mounted into api container)
# ------------------------------------------------------------
WORKSPACE_ROOT=./workspace
