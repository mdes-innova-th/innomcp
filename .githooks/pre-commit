#!/bin/sh
# INNOMCP pre-commit hook (offline, deterministic, non-interactive)
# - NEVER prompts
# - NEVER requires backend running
# - Runs only serverless/static checks suitable for pre-commit

set -u
set -o igncr 2>/dev/null || true

echo ""
echo "Pre-commit (offline, non-interactive)"
echo "====================================="

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "${ROOT}" ]; then
  echo "❌ Could not determine repo root"
  exit 1
fi

NODE_DIR="$ROOT/innomcp-node"
LOG_DIR="$NODE_DIR/logs/precommit"
TS="$(date +%Y%m%d-%H%M%S)"
LOG_FILE="$LOG_DIR/precommit-$TS.log"

mkdir -p "$LOG_DIR" 2>/dev/null || true

# ---------------------------------------------------------------------------
# Cold-start safety checks (Phase 6 post-mortem: multer missing-package bug)
# These run BEFORE static checks so startup crashes are caught early.
# Both checks are skipped when there is no build yet.
# ---------------------------------------------------------------------------

echo ""
echo "Cold-start dependency check..."

if [ -f "$NODE_DIR/dist/app.js" ]; then
  # 1) Missing runtime packages — catches "multer not installed" class of bugs
  node --max-old-space-size=512 -e "
    var pkg = require('$NODE_DIR/package.json');
    var fs = require('fs');
    var path = require('path');
    var deps = Object.keys(pkg.dependencies || {});
    // Skip @types/* (type-only, not runtime modules) and scoped packages that are
    // declaration-only — check by directory existence in node_modules instead of
    // require.resolve (which fails for ESM-only and type-only packages).
    var missing = deps.filter(function(d) {
      if (d.startsWith('@types/')) return false; // type-only, never runtime
      var dir = path.join('$NODE_DIR', 'node_modules', d);
      return !fs.existsSync(dir);
    });
    if (missing.length > 0) {
      console.error('Missing runtime packages: ' + missing.join(', '));
      console.error('Fix: cd innomcp-node && npm install');
      process.exit(1);
    }
    console.log('All runtime dependencies installed');
  " 2>&1
  DEP_RC=$?

  if [ $DEP_RC -ne 0 ]; then
    echo ""
    echo "ERROR: Server would crash on startup. Run npm install in innomcp-node/"
    exit 1
  fi

  # 2) Module resolution dry-run — catches missing dist files, broken requires
  echo "Cold-start module resolution check..."
  node --max-old-space-size=512 -e "
    try {
      require('$NODE_DIR/dist/app.js');
      console.log('✅ Module resolution OK');
      process.exit(0);
    } catch(e) {
      console.error('❌ Module resolution FAILED: ' + e.message);
      process.exit(1);
    }
  " 2>&1
  MOD_RC=$?

  if [ $MOD_RC -ne 0 ]; then
    echo ""
    echo "ERROR: Server would crash on startup. Run npm install in innomcp-node/"
    exit 1
  fi
else
  echo "⚠️  dist/app.js not found — cold-start checks skipped (run npm run build first)"
fi

# Optional healthcheck (ignored on failure). Default is offline.
if [ -n "${HOOK_HEALTHCHECK_URL:-}" ] && [ "${SKIP_HOOK_HEALTHCHECK:-0}" != "1" ]; then
  echo "Healthcheck: $HOOK_HEALTHCHECK_URL"
  if curl -fsS "$HOOK_HEALTHCHECK_URL" >/dev/null 2>&1; then
    echo "✅ Healthcheck OK"
  else
    echo "⚠️  Healthcheck failed (ignored)"
  fi
else
  echo "Healthcheck: skipped (offline default)"
fi

echo ""
echo "Running static checks (TypeScript: noEmit)..."

# Phase 10.64 — give tsc 8 GB heap. Larger MCP catalogue (56 tools, deep
# zod schemas) trips the 4 GB default when run alongside the dev stack.
export NODE_OPTIONS="--max-old-space-size=8192"

# [mcp] tsc is intentionally excluded from pre-commit checks.
# The MCP server has 56 tool schemas with deep zod + MCP SDK generics;
# tsc --noEmit requires >16 GB heap at commit time (concurrent with dev
# servers). The server runs under ts-node which does type-erasure, not
# type-checking, so runtime is unaffected. Run manually when needed:
#   cd innomcp-server-node && NODE_OPTIONS=--max-old-space-size=16384 npx tsc --noEmit
{
  echo "[node] tsc --noEmit"
  cd "$NODE_DIR" || exit 1
  npx tsc -p tsconfig.json --noEmit

  echo ""
  echo "[mcp] tsc --noEmit: SKIPPED (>8 GB heap needed; see hook comment)"
} > "$LOG_FILE" 2>&1

if [ $? -eq 0 ]; then
  echo "PASS"
  echo "Log: $LOG_FILE"
  exit 0
fi

echo "FAIL"
echo "Log: $LOG_FILE"
echo "Last 80 lines:"
tail -n 80 "$LOG_FILE" 2>/dev/null || true
exit 1
