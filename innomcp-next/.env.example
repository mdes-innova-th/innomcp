# Example environment file (DO NOT put secrets in git)

# Next.js
NODE_ENV=development

# App
HOST=localhost
PORT=3000

# Auth / cookies
JWT_SECRET=
TOKEN_NAME=token
COOKIE_DOMAIN=

# Backend/MCP wiring (adjust per environment)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3011
NEXT_PUBLIC_WS_URL=ws://localhost:3011
