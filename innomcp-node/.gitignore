# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# 
/out/

# production
/build
/dist
/.turbo

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# UI smoke runner (keep summary evidence log, ignore service stdout/stderr)
/evidence/ui-smoke-*.out.log
/evidence/ui-smoke-*.err.log

# env files (can opt-in for committing if needed)
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo

*.pem
/temp
/tmp

# local scratch scripts (verification / debug helpers)
/scripts/*

# Allow committing deterministic Phase 6.5 runner
!/scripts/verify_weather_v2.ts

# Phase W1: Weather Accuracy Recovery verifiers
!/scripts/verify_weather_accuracy_v1.ts
!/scripts/verify_phaseW1_weather_tracev3.ts

# Phase 7.4: General Intelligence Hardening verifier
!/scripts/verify_phase74_general_25cases.ts

# Phase 8: LLM as Renderer Only (NO decision-making) verifier
!/scripts/verify_phase8_renderer_only.ts

# Phase 8.1: Answer Quality Lock (UI-real Thai) verifier
!/scripts/verify_phase81_answer_quality.ts

# Phase 8.2: Non-seeded Robustness (still renderer-only) verifier
!/scripts/verify_phase82_robustness.ts

# Phase 8.3: Professional Answer Polish (still renderer-only) verifier
!/scripts/verify_phase83_answer_polish.ts

# Phase 8.4: Weather Resilience verifier
!/scripts/verify_phase84_weather_resilience.ts

# Phase 8.5: WX Accuracy + Cancel Accounting verifier
!/scripts/verify_phase85_weather_accuracy_cancel.ts

# Phase 8.6: Weather Accuracy & Coverage verifier
!/scripts/verify_phase86_weather_accuracy_coverage.ts

# Phase 8.6.1: WX NWP Fallback Guard verifier
!/scripts/verify_phase86_1_weather_nwp_guard.ts

# Phase 8.7: Weather Resolver Accuracy + Log Hygiene verifier
!/scripts/verify_phase87_weather_resolver_loghygiene.ts

# Phase 8.8: Logging Hygiene Hardening verifier
!/scripts/verify_phase88_log_hygiene.ts

# Phase 8.9: Weather-only UX + station accuracy verifier
!/scripts/verify_phase89_weather_ux_station_accuracy.ts

# Phase 8.10A: Weather reliability verifier
!/scripts/verify_phase810a_weather_reliability.ts

# Phase 8.10B: Router resilience verifier
