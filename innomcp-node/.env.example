# ============================================================
# innomcp-node (backend/chat) — Environment Variables Reference
# ห้ามใส่ secret จริงในไฟล์นี้ — copy เป็น .env แล้วกรอกค่าจริง
# ============================================================

# ------------------------------------------------------------
# OPERATING MODE (กติกาหลัก — ต้องตรงกับ innomcp-server-node)
# offline = ห้ามยิง external API, ใช้ fixture/smoke, ไม่ต้องมี key จริง
# online  = ต้องมี key จริงครบ (TMD_UID_API + NWP_API_KEY + MCP server พร้อม)
# ------------------------------------------------------------
INNOMCP_MODE=offline

# SMOKE_MODE=1 เปิดโหมด smoke-test (ใช้ร่วมกับ offline)
SMOKE_MODE=0

# Fixture/QA flags
WEATHER_FIXTURE_W1=0   # 1 = ใช้ weather fixture w1 แทน API จริง
CHAT_TRACE_QA=0        # 1 = เปิด chat trace สำหรับ QA

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
SERVER_HOST=127.0.0.1
SERVER_PORT=3011
LOG_MODE=dev

# MCP server URL (innomcp-server-node)
MCPSERVER_URL=http://localhost:3012/mcp

# ------------------------------------------------------------
# App DB (MariaDB)
# ------------------------------------------------------------
# ⚠️ PORT: Docker maps container:3306 → host:3308 (mariadb/docker-compose.yml)
#   - Running on HOST (npm run dev): DB_HOST=127.0.0.1, DB_PORT=3308
#   - Running in DOCKER (compose):   DB_HOST=mariadb,   DB_PORT=3306  ← override in docker-compose.yml
# ⚠️ CREDENTIALS: MARIADB_PASSWORD must match DB_PASSWORD (jlapps user)
#   Access denied error means MariaDB container has different MARIADB_PASSWORD than DB_PASSWORD here
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=jlapps
DB_PASSWORD=
DB_NAME=innomcp-db

# Docker MariaDB — MARIADB_PASSWORD must match DB_PASSWORD above
MARIADB_ROOT_PASSWORD=
MARIADB_PASSWORD=

# ------------------------------------------------------------
# DetectDB (Evidence DB)
# ------------------------------------------------------------
DETECT_DB_HOST=127.0.0.1
DETECT_DB_PORT=3308
DETECT_DB_USER=root
DETECT_DB_PASSWORD=
DETECT_DB_NAME=phase91_detectdb

# ------------------------------------------------------------
# TMD Credentials (ต้องตรงกับ innomcp-server-node/.env)
# Phase 10.9+: แยกเป็น 2 tier — api (v2 real-time) และ demo (v1 public)
#
# tier "api"  → TMD_UID_API / TMD_UKEY_API
#   ใช้กับ: WeatherToday/V2, Weather3Hours/V2, WeatherForecast7Days/v2,
#           DailyForecast/v2, WeatherWarningNews/v2, WeatherForecast7DaysByRegion/v2,
#           Weather3HoursByHydro/V1, Weather3HoursByAgro/V1, Weather3HoursBySynop/V1,
#           WeatherTodayByHydro/V1, WeatherTodayByAgro/V1, weathertodayBySynop/V1
#
# tier "demo" → TMD_UID_DEMO / TMD_UKEY_DEMO (default: demo/demo — public datasets)
#   ใช้กับ: DailySeismicEvent/v1, ThailandClimateNormal/v1,
#           ThailandMonthlyRainfall/v1, RainRegions/v1, Station/v1
#
# Fallback chain: TMD_UID_API (or DEMO) → TMD_UID / TMD_UKEY (deprecated)
# สมัคร registered credentials: https://data.tmd.go.th/
# ------------------------------------------------------------
TMD_UID_API=
TMD_UKEY_API=
TMD_UID_DEMO=demo
TMD_UKEY_DEMO=demo

# [DEPRECATED] TMD_UID / TMD_UKEY — ใช้เป็น fallback เท่านั้น
TMD_UID=
TMD_UKEY=

# ------------------------------------------------------------
# NWP API (National Weather Prediction — TMD HPC)
# JWT Bearer token ต้องมี 4 scopes ครบ:
#   nwp.api.forecast_location   → nwp_daily_by_place (province/amphoe/tambon)
#   nwp.api.location.forecast_daily   → nwp_daily_by_location (lat/lon)
#   nwp.api.location.forecast_hourly  → nwp_hourly_by_location + nwp_hourly_by_place
#   nwp.api.forecast_area       → nwp_daily_by_region + nwp_hourly_by_region
#
# ขอ token (ต้องมีสิทธิ์เข้าถึง): https://data.tmd.go.th/nwpapi/
# ตรวจสอบ scopes: node -e "const j='<YOUR_JWT>'; const p=j.split('.')[1]; console.log(JSON.parse(Buffer.from(p,'base64').toString()).scopes)"
# ------------------------------------------------------------
NWP_API_KEY=

# ------------------------------------------------------------
# LLM (Ollama — local pipeline)
# ------------------------------------------------------------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b

# ------------------------------------------------------------
# Phase 10.15: Parallel MDES Agent Dispatch
# ------------------------------------------------------------
# OLLAMA_URL: MDES Ollama endpoint for parallel agents
#   Default (if unset): https://ollama.mdes-innova.online
OLLAMA_URL=https://ollama.mdes-innova.online

# OLLAMA_API_KEY: API key for MDES Ollama
#   Required for real MDES dispatch. Leave empty to skip MDES calls silently.
OLLAMA_API_KEY=

# PARALLEL_AGENTS: Feature flag for multi-agent dispatch
#   "0"  → disabled (panel renders from conductor events only, no MDES calls)
#   "1"  → enabled  (requires OLLAMA_API_KEY to be non-empty)
#   Recommended for first deploy: PARALLEL_AGENTS=0
PARALLEL_AGENTS=0

# MCP server URL
MCPSERVER_URL=http://localhost:3012/mcp


# ------------------------------------------------------------
# Phase C.18: MDES-Only mode
# ------------------------------------------------------------
# MDES_ONLY: Force all agent compute to stay on ollama.mdes only.
#   "1"  → skip localhost fallback; skip GPT fallback entirely
#   unset/other → default escalation (MDES → localhost → GPT if key set)
#   Set this when you want zero calls outside ollama.mdes-innova.online
MDES_ONLY=1

# ------------------------------------------------------------
# Phase 18+: Mother Dispatch — 13-Provider Roster
# Each provider fires in parallel on every chat message.
# Providers without a key are skipped silently (no network call).
# Always-on (key-free): ollama-local + innova-bot
# ------------------------------------------------------------

# MDES Cloud + Thai LLM (shared key)
REMOTE_OLLAMA_TOKEN=
REMOTE_OLLAMA_BASE_URL=https://ollama.mdes-innova.online
MDES_PRIMARY_MODEL=gemma4:26b
THAI_LLM_MODEL=qwen3.5:9b

# OpenAI GPT (gpt-4o-mini default)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude Haiku + Claude Sonnet — shared key)
ANTHROPIC_API_KEY=
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6

# GitHub Copilot
GITHUB_COPILOT_TOKEN=
COPILOT_BASE_URL=https://api.githubcopilot.com
COPILOT_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner

# Groq (ultra-fast inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Together AI
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Innova-Bot (local key-free agent — uses same Ollama as OLLAMA_HOST)
INNOVA_BOT_BASE_URL=http://localhost:11434
INNOVA_BOT_MODEL=qwen2.5:0.5b

# Innova-Bot Oracle Gateway (RAG knowledge base — requires innova-bot gateway)
# Start: cd C:/Users/USER-NT/innova-bot && start_sse.cmd (gateway starts on :8000)
INNOVA_GATEWAY_URL=http://localhost:8000
GATEWAY_PORT=8000

# Synthesis model (MDES fast model used to merge top-3 provider responses)
MDES_SYNTHESIS_MODEL=gemma4:e4b
