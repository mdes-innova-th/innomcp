```env
# .env.example สำหรับ innomcp-node
# ให้คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าตามความเหมาะสม

# ---------- MDES Ollama (Primary AI) ----------
# URL ของ Ollama บนคลาวด์ของ MDES สำหรับ AI หลัก
MDES_OLLAMA_URL=https://ollama.mdes-innova.online
# API Key สำหรับยืนยันสิทธิ์กับ Ollama ของ MDES
MDES_API_KEY=your_mdes_api_key_here

# ---------- Local Ollama (fallback) ----------
# URL ของ Ollama ที่รันในเครื่อง (ใช้แทนเมื่อ MDES Ollama ขัดข้อง)
LOCAL_OLLAMA_BASE_URL=http://localhost:11434
# ค่ามาตรฐานของ OLLAMA_BASE_URL ที่ไลบรารี Ollama ใช้
OLLAMA_BASE_URL=http://localhost:11434

# ---------- Backend Configuration ----------
# พอร์ตของเซิร์ฟเวอร์ Express
PORT=3011
# สภาพแวดล้อมการทำงาน (development, production, test)
NODE_ENV=development

# ---------- Authentication ----------
# Secret Key สำหรับสร้างและตรวจสอบ JSON Web Token (ต้องมีความยาวอย่างน้อย 32 ตัวอักษร)
JWT_SECRET=minimum_32_chars_secret_here_change_in_production
# อายุของ JWT ก่อนหมดอายุ (เช่น 7d, 24h, 1y)
JWT_EXPIRES_IN=7d

# ---------- Database ----------
# URL เชื่อมต่อฐานข้อมูล MySQL สำหรับ Prisma
DATABASE_URL=mysql://user:password@localhost:3306/innomcp

# ---------- Redis (Session Persistence) ----------
# URL เชื่อมต่อ Redis สำหรับเก็บเซสชันและแคช (ไม่จำเป็นต้องมี)
REDIS_URL=redis://localhost:6379

# ---------- Workspace ----------
# ไดเรกทอรีที่ใช้เก็บไฟล์ workspace ของผู้ใช้
WORKSPACE_BASE_PATH=./workspace-storage

# ---------- Analytics ----------
# เปิด/ปิดการเก็บข้อมูลวิเคราะห์การใช้งาน (true/false)
ANALYTICS_ENABLED=true
# ที่ตั้งของไฟล์ audit log ในรูปแบบ JSON lines
AUDIT_LOG_PATH=./logs/audit.jsonl

# ---------- Thai LLM (Optional) ----------
# ตัวระบุโมเดล LLM ภาษาไทย (ถ้ามี) สำหรับความสามารถการประมวลผลภาษาไทยขั้นสูง
THAI_LLM_MODEL=
# API Key สำหรับบริการ LLM ภาษาไทย (ถ้าต้องการใช้)
THAI_LLM_API_KEY=

# ---------- OpenAI Compatible (Optional) ----------
# API Key ของ OpenAI หรือบริการที่เข้ากันได้ (เช่น GPT-4)
OPENAI_API_KEY=
# คีย์สำรองสำหรับ API ที่เข้ากันกับ GPT (ใช้ในบางกรณี)
GPT_API_KEY=

# ---------- CORS ----------
# URL ของ Frontend ที่อนุญาตให้เรียก API ข้ามโดเมน
FRONTEND_URL=http://localhost:3000
```