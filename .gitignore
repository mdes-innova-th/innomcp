# Allowlist: unit and integration tests (real coverage, not passWithNoTests)
!innomcp-node/tests/unit/
!innomcp-node/tests/unit/__tests__/
!innomcp-node/tests/unit/__tests__/*.ts
!innomcp-node/tests/unit/*.test.ts
